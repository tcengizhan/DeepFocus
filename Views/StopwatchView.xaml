<UserControl x:Class="DeepFocus.Views.StopwatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding DisplayTime}" Style="{StaticResource LargeTimeTextStyle}" />
            <UniformGrid Columns="3" Margin="0,44,0,36">
                <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="LAP" Command="{Binding LapCommand}" Style="{StaticResource ActionButtonStyle}" Margin="10,0" />
                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ActionButtonStyle}" />
            </UniformGrid>
        </StackPanel>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Laps}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource DeepFocusTextSecondaryBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Number, StringFormat=LAP {0}}" Style="{StaticResource WideTextStyle}" Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding DisplayTime}" Style="{StaticResource WideTextStyle}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
