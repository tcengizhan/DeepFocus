<UserControl x:Class="DeepFocus.Views.ClockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.72*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.28*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Time}" Style="{StaticResource LargeTimeTextStyle}" />
                <TextBlock Text="{Binding Seconds}"
                           Foreground="{StaticResource DeepFocusWhiteBrush}"
                           Opacity="0.42"
                           FontSize="22"
                           FontWeight="ExtraLight"
                           Margin="8,30,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding Date}"
                       Style="{StaticResource SmallCapsTextStyle}"
                       Margin="0,6,0,68" />

            <TextBlock Text="G&#252;nl&#252;k &#199;al&#305;&#351;ma Hedefi"
                       Style="{StaticResource SmallCapsTextStyle}"
                       Margin="0,0,0,12" />
            <ProgressBar Width="300"
                         Maximum="1"
                         Value="{Binding DailyGoalProgress}"
                         Style="{StaticResource ThinGoalProgressStyle}" />
            <TextBlock Text="{Binding DailyGoalPercentText}"
                       Style="{StaticResource SmallCapsTextStyle}"
                       Margin="0,8,0,0" />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,44,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Card Style="{StaticResource DeepFocusCardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="G&#252;nl&#252;k Seri" Style="{StaticResource SmallCapsTextStyle}" />
                    <TextBlock Text="{Binding DailyStreakDisplay}"
                               Style="{StaticResource WideTextStyle}"
                               FontSize="28"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="1" Style="{StaticResource DeepFocusCardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="En Uzun Oturum" Style="{StaticResource SmallCapsTextStyle}" />
                    <TextBlock Text="{Binding LongestSession}"
                               Style="{StaticResource WideTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="2" Style="{StaticResource DeepFocusCardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Bu Hafta" Style="{StaticResource SmallCapsTextStyle}" />
                    <TextBlock Text="{Binding WeeklyComparison}"
                               Style="{StaticResource WideTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
