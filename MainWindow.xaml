<ui:FluentWindow x:Class="DeepFocus.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:DeepFocus.Views"
                 Title="DeepFocus"
                 Width="480"
                 Height="780"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="None"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize"
                 Background="{StaticResource DeepFocusBackgroundBrush}">
    <Border Background="{StaticResource DeepFocusBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource DeepFocusBackgroundBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="D E E P F O C U S"
                           Style="{StaticResource ChromeTitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0" />

                <ui:Button Grid.Column="1"
                           Content="-"
                           Appearance="Secondary"
                           Style="{StaticResource ChromeButtonStyle}"
                           Click="OnMinimizeClick" />
                <ui:Button Grid.Column="2"
                           Content="X"
                           Appearance="Secondary"
                           Style="{StaticResource ChromeButtonStyle}"
                           Click="OnCloseClick" />
            </Grid>

            <TabControl Grid.Row="1"
                        Style="{StaticResource BottomTabControlStyle}"
                        SelectionChanged="OnTabSelectionChanged">
                <TabItem Style="{StaticResource BottomTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Style="{StaticResource TabHeaderStackStyle}">
                            <ui:SymbolIcon Symbol="Clock24"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                            <TextBlock Text="SAAT" Style="{StaticResource TabLabelTextStyle}" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:ClockView DataContext="{Binding Clock}" />
                </TabItem>

                <TabItem Style="{StaticResource BottomTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Style="{StaticResource TabHeaderStackStyle}">
                            <ui:SymbolIcon Symbol="Timer24"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                            <TextBlock Text="KRONOMETRE" Style="{StaticResource TabLabelTextStyle}" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:StopwatchView DataContext="{Binding Stopwatch}" />
                </TabItem>

                <TabItem Style="{StaticResource BottomTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Style="{StaticResource TabHeaderStackStyle}">
                            <ui:SymbolIcon Symbol="HourglassHalf24"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                            <TextBlock Text="TIMER" Style="{StaticResource TabLabelTextStyle}" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:CountdownView DataContext="{Binding Countdown}" />
                </TabItem>

                <TabItem Style="{StaticResource BottomTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Style="{StaticResource TabHeaderStackStyle}">
                            <ui:SymbolIcon Symbol="ChartMultiple24"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                            <TextBlock Text="&#304;STAT&#304;ST&#304;K" Style="{StaticResource TabLabelTextStyle}" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:StatisticsView DataContext="{Binding Statistics}" />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</ui:FluentWindow>
