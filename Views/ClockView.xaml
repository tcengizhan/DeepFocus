<UserControl x:Class="DeepFocus.Views.ClockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Time}" Style="{StaticResource LargeTimeTextStyle}" />
                <TextBlock Text="{Binding Seconds}"
                           Foreground="{StaticResource DeepFocusSecondsBrush}"
                           FontSize="22"
                           FontWeight="ExtraLight"
                           Margin="8,30,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding Date}"
                       Style="{StaticResource SmallCapsTextStyle}"
                       Margin="0,6,0,56" />

            <Grid Width="300" Height="18">
                <Border Height="1"
                        Background="{StaticResource DeepFocusWhiteBrush}"
                        VerticalAlignment="Center" />
                <Ellipse Width="6"
                         Height="6"
                         Fill="{StaticResource DeepFocusWhiteBrush}"
                         HorizontalAlignment="Left"
                         Margin="126,0,0,0" />
            </Grid>
        </StackPanel>

        <UniformGrid Grid.Row="3" Columns="3" Margin="0,44,0,0">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Günlük Seri" Style="{StaticResource SmallCapsTextStyle}" />
                    <ItemsControl Margin="0,16,0,0">
                        <ItemsControl.Items>
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusWhiteBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusWhiteBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusWhiteBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusWhiteBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusLineBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusLineBrush}" Margin="3,0" />
                            <Ellipse Width="6" Height="6" Fill="{StaticResource DeepFocusLineBrush}" Margin="3,0" />
                        </ItemsControl.Items>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="En Uzun Oturum" Style="{StaticResource SmallCapsTextStyle}" />
                    <TextBlock Text="{Binding LongestSession}"
                               Style="{StaticResource WideTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Bu Hafta" Style="{StaticResource SmallCapsTextStyle}" />
                    <TextBlock Text="{Binding WeeklyComparison}"
                               Style="{StaticResource WideTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
