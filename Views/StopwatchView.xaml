<UserControl x:Class="DeepFocus.Views.StopwatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding DisplayTime}"
                       Style="{StaticResource LargeTimeTextStyle}"
                       Width="400"
                       FontSize="74"
                       FontFamily="Consolas"
                       TextAlignment="Center" />
            <UniformGrid Columns="3" Margin="0,44,0,36">
                <ui:Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource FluentActionButtonStyle}" />
                <ui:Button Content="TUR" Command="{Binding LapCommand}" Style="{StaticResource FluentActionButtonStyle}" Margin="10,0" />
                <ui:Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource FluentActionButtonStyle}" />
            </UniformGrid>
        </StackPanel>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Laps}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource DeepFocusTextSecondaryBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Label}" Style="{StaticResource WideTextStyle}" Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayTime}"
                                   Style="{StaticResource WideTextStyle}"
                                   FontFamily="Consolas"
                                   TextAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
