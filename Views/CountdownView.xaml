<UserControl x:Class="DeepFocus.Views.CountdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                <TextBox Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="96"
                         Background="Transparent"
                         BorderBrush="{StaticResource DeepFocusLineBrush}"
                         BorderThickness="0,0,0,1"
                         Foreground="{StaticResource DeepFocusWhiteBrush}"
                         FontSize="28"
                         FontWeight="Light"
                         TextAlignment="Center" />
                <TextBlock Text="min"
                           Style="{StaticResource WideTextStyle}"
                           Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="10,6,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding DisplayTime}" Style="{StaticResource LargeTimeTextStyle}" />
            <UniformGrid Columns="2" Margin="64,44,64,0">
                <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0" />
                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ActionButtonStyle}" Margin="8,0,0,0" />
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
