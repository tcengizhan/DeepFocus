<UserControl x:Class="DeepFocus.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="260" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:Card Style="{StaticResource DeepFocusCardStyle}" Padding="18">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="G&#252;nl&#252;k Hedef"
                       Style="{StaticResource WideTextStyle}"
                       Foreground="{StaticResource DeepFocusWhiteBrush}"
                       FontSize="18"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding DailyGoalHoursInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Width="92"
                     Height="42"
                     Background="{StaticResource DeepFocusBackgroundBrush}"
                     BorderBrush="{StaticResource DeepFocusCardBorderBrush}"
                     BorderThickness="1"
                     Foreground="{StaticResource DeepFocusWhiteBrush}"
                     FontSize="22"
                     FontWeight="Light"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center" />
            <TextBlock Grid.Column="2"
                       Text="saat"
                       Style="{StaticResource WideTextStyle}"
                       Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
            <Button Grid.Column="3"
                       Content="Kaydet"
                       Command="{Binding SaveDailyGoalCommand}"
                       Style="{StaticResource GlowActionButtonStyle}"
                       Margin="12,0,0,0" />
            <Button Grid.Row="1"
                       Grid.ColumnSpan="4"
                       Content="S&#305;f&#305;rla"
                       Command="{Binding ResetDailyGoalCommand}"
                       Style="{StaticResource GlowActionButtonStyle}"
                       HorizontalAlignment="Stretch"
                       Margin="0,14,0,0" />
        </Grid>
        </ui:Card>

        <lvc:CartesianChart Grid.Row="1"
                            Series="{Binding WeeklySeries}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            Background="Transparent"
                            LegendPosition="Hidden"
                            Margin="0,22,0,0" />

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Sessions}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                 Margin="0,28,0,0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="0">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#15ffffff" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="Transparent" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Mode}" Style="{StaticResource WideTextStyle}" />
                            <TextBlock Text="{Binding StartedAt, StringFormat={}{0:dd MMM HH:mm}}"
                                       Style="{StaticResource WideTextStyle}"
                                       Foreground="{StaticResource DeepFocusTextMutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DurationText}"
                                   Style="{StaticResource WideTextStyle}"
                                   Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Today's Timer Sessions -->
        <ui:Card Grid.Row="3"
                 Style="{StaticResource DeepFocusCardStyle}"
                 Margin="0,18,0,0"
                 Padding="16">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="BUG&#220;N&#220;N ZAMANLAYICILARI"
                           Style="{StaticResource SmallCapsTextStyle}"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding TodayTimerSessions}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                         MaxHeight="180"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionMode="Single">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{TemplateBinding Background}"
                                                Padding="4,2"
                                                CornerRadius="4">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#15ffffff" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="Transparent" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StartedAt, StringFormat={}{0:HH:mm}}"
                                           Style="{StaticResource WideTextStyle}"
                                           Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimerHistoryText}"
                                           Style="{StaticResource WideTextStyle}"
                                           Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </ui:Card>

        <!-- Toast notification -->
        <Border Grid.RowSpan="4"
                Width="240"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,18"
                Background="{StaticResource DeepFocusBackgroundBrush}"
                BorderBrush="{StaticResource DeepFocusCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                IsHitTestVisible="False"
                Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSaveToastVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBlock Text="{Binding SaveToastMessage}"
                       Style="{StaticResource WideTextStyle}"
                       Foreground="{StaticResource DeepFocusWhiteBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13" />
        </Border>
    </Grid>
</UserControl>
