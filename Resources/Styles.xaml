<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="WideTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DeepFocusTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontWeight" Value="ExtraLight" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="ChromeTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource WideTextStyle}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{StaticResource DeepFocusWhiteBrush}" />
    </Style>

    <Style x:Key="ChromeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DeepFocusTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DeepFocusWhiteBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="BorderBrush" Value="{StaticResource DeepFocusLineBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DeepFocusWhiteBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource DeepFocusWhiteBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BottomTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource DeepFocusBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="TabStripPlacement" Value="Bottom" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="76" />
                        </Grid.RowDefinitions>
                        <ContentPresenter Grid.Row="0"
                                          ContentSource="SelectedContent"
                                          Margin="0"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        <UniformGrid Grid.Row="1"
                                     Rows="1"
                                     Columns="4"
                                     IsItemsHost="True"
                                     KeyboardNavigation.TabIndex="1"
                                     Background="{StaticResource DeepFocusBackgroundBrush}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BottomTabItemStyle" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource DeepFocusTextMutedBrush}" />
        <Setter Property="Height" Value="76" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FontWeight" Value="ExtraLight" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Background="{StaticResource DeepFocusBackgroundBrush}">
                        <Grid>
                            <Border x:Name="ActiveLine"
                                    Height="1"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource DeepFocusWhiteBrush}"
                                    Opacity="0" />
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ActiveLine" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{StaticResource DeepFocusWhiteBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DeepFocusTextPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabHeaderStackStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="TabIconTextStyle" TargetType="TextBlock" BasedOn="{StaticResource WideTextStyle}">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
    </Style>

    <Style x:Key="TabLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource WideTextStyle}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
    </Style>

    <Style x:Key="LargeTimeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource WideTextStyle}">
        <Setter Property="FontSize" Value="84" />
        <Setter Property="FontWeight" Value="ExtraLight" />
        <Setter Property="Foreground" Value="{StaticResource DeepFocusWhiteBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SmallCapsTextStyle" TargetType="TextBlock" BasedOn="{StaticResource WideTextStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource DeepFocusTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DeepFocusCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DeepFocusCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="MinHeight" Value="104" />
    </Style>
</ResourceDictionary>
