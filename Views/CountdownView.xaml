<UserControl x:Class="DeepFocus.Views.CountdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:NumberBox Value="{Binding Minutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Minimum="1"
                              MinWidth="120"
                              FontSize="28"
                              FontWeight="Light"
                              TextAlignment="Center" />
                <TextBlock Text="min"
                           Style="{StaticResource WideTextStyle}"
                           Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="10,6,0,0" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding DisplayTime}" Style="{StaticResource LargeTimeTextStyle}" />
            <UniformGrid Columns="2" Margin="64,44,64,0">
                <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource GlowActionButtonStyle}" Margin="0,0,8,0" />
                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource GlowActionButtonStyle}" Margin="8,0,0,0" />
            </UniformGrid>
        </StackPanel>

        <ui:Card Grid.Row="3"
                 Style="{StaticResource DeepFocusCardStyle}"
                 Margin="0,24,0,0"
                 Padding="16">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="Timer Ge&#231;mi&#351;i"
                           Style="{StaticResource SmallCapsTextStyle}"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding TimerHistory}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                         MaxHeight="210"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionMode="NoSelection">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="{TemplateBinding Background}"
                                                Padding="4,2"
                                                CornerRadius="4">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#15ffffff" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TimerHistoryText}"
                                       Style="{StaticResource WideTextStyle}"
                                       Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                                       Margin="0,5" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </ui:Card>

        <Grid Grid.RowSpan="4"
              Background="#cc040b11">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompletionOverlayVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <ui:Card Width="320"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Background="{StaticResource DeepFocusBackgroundBrush}"
                     BorderBrush="{StaticResource DeepFocusCardBorderBrush}"
                     BorderThickness="1"
                     Padding="28">
                <StackPanel>
                    <TextBlock Text="S&#252;re Doldu! &#x1F3AF;"
                               Style="{StaticResource WideTextStyle}"
                               Foreground="{StaticResource DeepFocusWhiteBrush}"
                               FontSize="28"
                               FontWeight="Light"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding CompletedDurationText}"
                               Style="{StaticResource SmallCapsTextStyle}"
                               Margin="0,12,0,24" />
                    <Button Content="Tamam"
                               Command="{Binding DismissCompletionCommand}"
                               Style="{StaticResource GlowActionButtonStyle}"
                               HorizontalAlignment="Stretch" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
