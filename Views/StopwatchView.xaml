<UserControl x:Class="DeepFocus.Views.StopwatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding DisplayTime}"
                       Style="{StaticResource LargeTimeTextStyle}"
                       Width="400"
                       FontSize="74"
                       FontFamily="Consolas"
                       TextAlignment="Center" />
            <UniformGrid Columns="3" Margin="0,44,0,36">
                <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource GlowActionButtonStyle}" />
                <Button Content="TUR" Command="{Binding LapCommand}" Style="{StaticResource GlowActionButtonStyle}" Margin="10,0" />
                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource GlowActionButtonStyle}" />
            </UniformGrid>

            <Button Content="&#199;al&#305;&#351;maya Ekle"
                    Command="{Binding AddToWorkCommand}"
                    HorizontalAlignment="Center"
                    Padding="24,8"
                    Margin="0,0,0,16">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource GlowActionButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAddToWorkVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Laps}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource DeepFocusTextSecondaryBrush}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource DeepFocusBackgroundBrush}"
                            BorderBrush="{StaticResource DeepFocusLineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" Style="{StaticResource WideTextStyle}" Foreground="{StaticResource DeepFocusTextSecondaryBrush}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DisplayTime}"
                                       Style="{StaticResource WideTextStyle}"
                                       FontFamily="Consolas"
                                       TextAlignment="Right" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add to work toast -->
        <Border Grid.RowSpan="4"
                Width="280"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,18"
                Background="{StaticResource DeepFocusBackgroundBrush}"
                BorderBrush="{StaticResource DeepFocusCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                IsHitTestVisible="False"
                Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddToWorkToastVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBlock Text="S&#252;re &#231;al&#305;&#351;ma saatine eklendi &#x2713;"
                       Style="{StaticResource WideTextStyle}"
                       Foreground="{StaticResource DeepFocusWhiteBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13" />
        </Border>
    </Grid>
</UserControl>
