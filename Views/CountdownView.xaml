<UserControl x:Class="DeepFocus.Views.CountdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{StaticResource DeepFocusBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:NumberBox Value="{Binding Minutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Minimum="1"
                              MinWidth="120"
                              FontSize="28"
                              FontWeight="Light"
                              TextAlignment="Center" />
                <TextBlock Text="min"
                           Style="{StaticResource WideTextStyle}"
                           Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="10,6,0,0" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding DisplayTime}" Style="{StaticResource LargeTimeTextStyle}" />
            <UniformGrid Columns="2" Margin="64,44,64,0">
                <ui:Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource FluentActionButtonStyle}" Margin="0,0,8,0" />
                <ui:Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource FluentActionButtonStyle}" Margin="8,0,0,0" />
            </UniformGrid>
        </StackPanel>

        <ui:Card Grid.Row="3"
                 Style="{StaticResource DeepFocusCardStyle}"
                 Margin="0,24,0,0"
                 Padding="16">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="Timer Ge&#231;mi&#351;i"
                           Style="{StaticResource SmallCapsTextStyle}"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding TimerHistory}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                         MaxHeight="210"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TimerHistoryText}"
                                       Style="{StaticResource WideTextStyle}"
                                       Foreground="{StaticResource DeepFocusTextSecondaryBrush}"
                                       Margin="0,5" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </ui:Card>
    </Grid>
</UserControl>
